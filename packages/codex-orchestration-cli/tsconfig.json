{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022",
    "types": ["node"]
  },
  "include": [
    "bin/**/*.ts",
    "hooks/**/*.ts",
    "scripts/**/*.ts",
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "runtime", "skills"]
}
